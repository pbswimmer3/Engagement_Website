# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in your Supabase project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Site Passwords (per invite group) ────────────────────────────────────────
# Each invite group has its own password. Which password a guest enters decides
# which set of names they can see on the RSVP page.
#
# SITE_PASSWORD_PRAANYA falls back to SITE_PASSWORD (legacy) which falls back
# to "Forever2026" — so existing deployments keep working until Jain and Biswas
# guests are added.
SITE_PASSWORD_PRAANYA=Forever2026
SITE_PASSWORD_JAIN=
SITE_PASSWORD_BISWAS=

# Legacy fallback for the Praanya group only (optional).
# SITE_PASSWORD=Forever2026

# ──────────────────────────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in your Supabase values above
# 3. In Vercel: add these same variables under Project → Settings → Environment Variables
